{
  "name": "lumira",
  "version": "0.2.0",
  "description": "lumira — real-time statusline for Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "lumira": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "^3.1.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cativo23/lumira.git"
  },
  "keywords": [
    "claude-code",
    "claude",
    "statusline",
    "terminal",
    "nerd-font",
    "hud",
    "metrics",
    "pulse"
  ],
  "files": [
    "dist",
    "skills"
  ]
}
